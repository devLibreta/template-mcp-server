# ============================================================
# MCP 개발용 Devcontainer — 런타임 환경 준비
# 소스 코드는 호스트에서 마운트하는 것을 전제로 하며,
# 이 Dockerfile 자체는 Node.js 런타임 + pnpm + 도구만 설치합니다.
# ============================================================
FROM node:22-alpine

# 시스템 도구 설치 (비대화형 보장)
RUN apk add --no-cache \
    git \
    openssh-client \
    curl \
    bash \
    zsh \
    vim

# pnpm 설치 — corepack 없이 npm으로 직접 설치 (비대화형 보장)
# corepack enable은 "download confirmation" 프롬프트를 유발할 수 있으므로 회피
RUN npm install -g pnpm@11

# 작업 디렉토리 (호스트 소스가 마운트될 위치)
WORKDIR /workspace

# 비-root 유저(node)로 전환 (node:22-alpine에 기본 포함)
USER node

# 기본 셸 설정
SHELL ["/bin/zsh", "-c"]

# 컨테이너 시작 시 대기 (Devcontainer가 소스를 마운트할 시간 확보)
CMD ["sleep", "infinity"]
